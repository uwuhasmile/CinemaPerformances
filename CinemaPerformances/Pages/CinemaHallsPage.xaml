<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:CinemaPerformances.Pages"
             xmlns:models="clr-namespace:CinemaPerformances.DTOModels;assembly=CinemaPerformances.DTOModels"
             xmlns:vm="clr-namespace:CinemaPerformances.ViewModels"
             xmlns:tools="clr-namespaces:CinemaPerformances.Tools"
             x:Class="CinemaPerformances.Pages.CinemaHallsPage"
             x:DataType="pages:CinemaHallsPage"
             Title="Cinema Halls">
    <CollectionView
        ItemsSource="{Binding CinemaHalls}"
        Margin="10"
        SelectionMode="Single"
        SelectedItem="{Binding SelectedCinemaHall}"
        SelectionChangedCommand="{Binding CinemaHallSelectedCommand}">
        <CollectionView.ItemTemplate>
            <DataTemplate
                x:DataType="models:CinemaHallListDTO">
                <Border
                    Stroke="CornflowerBlue"
                    Padding="10"
                    Margin="0,10">
                    <VerticalStackLayout>
                        <Label
                            Text="{Binding Name}"
                            Style="{StaticResource SubHeadline}"
                            HorizontalOptions="Start" />
                        <Label>
                            <MultiBinding StringFormat="{}{0}, {1} seats">
                                <Binding Path="Type" Converter="{StaticResource EnumToDisplayName}" />
                                <Binding Path ="Seats" />
                            </MultiBinding>
                        </Label>
                        <Label>
                            <MultiBinding StringFormat="Total duration: {0} minutes">
                                <Binding Path="TotalDuration" />
                            </MultiBinding>
                        </Label>
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>