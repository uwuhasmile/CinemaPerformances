<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CinemaPerformances.UIModels;assembly=CinemaPerformances.UIModels"
             xmlns:tools="clr-namespaces:CinemaPerformances.Tools"
             x:Class="CinemaPerformances.Pages.PerformanceDetailsPage"
             Title="Performance Details">
    <ScrollView>
        <VerticalStackLayout
            Padding="10,20"
            Spacing="10">
            <Label
                Style="{StaticResource SubHeadline}"
                HorizontalOptions="Start"
                Text="{Binding Name}" />
            <Label Text="Duration" />
            <Label Margin="10,0" Text="{Binding Duration, StringFormat='{0} minutes'}"/>
            <Label
                Text="Span" />
            <Label Margin="10,0">
                <MultiBinding StringFormat="{}{0:HH:mm} - {1:HH:mm}">
                    <Binding Path="Start" />
                    <Binding Path="End" />
                </MultiBinding>
            </Label>
            <Label Text="Genre" />
            <Label Margin="10,0" Text="{Binding Genre, Converter={StaticResource EnumToDisplayName}}"/>
            <Label Text="Release date" />
            <Label Margin="10,0" Text="{Binding ReleaseDate, StringFormat='{0:d MMMM, yyyy}'}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>